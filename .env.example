# Runtime
APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# Pipeline
DRY_RUN=true
TARGET_ARTICLE_COUNT=8
DOMESTIC_RATIO=0.0
RECENT_PUBLISHED_DAYS=14
MIN_TIER_A_RATIO=0.3
QUALITY_THRESHOLD=80
REQUIRE_LLM_FOR_PUBLISH=true
ALLOW_GOOGLE_REDIRECT_CITATION=false
STRICT_WEB_PUBLISHED_AT=true
MAX_ENTRIES_PER_SOURCE=4
MAX_ARTICLE_AGE_HOURS=168
MAX_TIER_A_ARTICLE_AGE_HOURS=8760

# LLM (optional; primary: gpt-5.5, backup: deepseek-v4-pro, secondary: DeepSeek Anthropic, fallback: Grok)
LLM_API_KEY=
LLM_BASE_URL=http://64.83.41.79:18085/v1
LLM_MODEL=gpt-5.5
LLM_MAX_TOKENS=6000
LLM_TEMPERATURE=0.1
LLM_BACKUP_API_KEY=
LLM_BACKUP_BASE_URL=http://64.83.41.79:18086
LLM_BACKUP_MODEL=deepseek-v4-pro
LLM_SECONDARY_BACKUP_API_KEY=
LLM_SECONDARY_BACKUP_BASE_URL=https://api.deepseek.com/anthropic
LLM_SECONDARY_BACKUP_MODEL=deepseek-v4-pro
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=https://grok.223344567.xyz/v1
LLM_FALLBACK_MODEL=grok-4.20-0309-non-reasoning

# WeChat Official Account
WECHAT_ENABLE_PUBLISH=false
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AUTHOR=Global Aviation Digest
WECHAT_THUMB_MEDIA_ID=
WECHAT_PROXY=
WEB_DIGEST_BASE_URL=https://flighttoolbox.hudawang.cn/digest
COPYRIGHT_NOTICE_URL=

# Alerts
ALERT_WEBHOOK_URL=

# Podcast TTS
DASHSCOPE_API_KEY=
QWEN_TTS_URL=http://localhost:8825

# PDF Extraction & Narration
MINERU=

# Self-hosted static site
STATIC_ROOT=/www/wwwroot/flighttoolbox-static/current
STATIC_PUBLIC_BASE_URL=https://flighttoolbox.hudawang.cn

# Image Generation
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=https://grok.223344567.xyz
IMAGE_GEN_MODEL=grok-imagine-image-lite
IMAGE_GEN_BACKUP_API_KEY=
IMAGE_GEN_BACKUP_BASE_URL=
IMAGE_GEN_BACKUP_MODEL=

# Runtime
APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# Pipeline
DRY_RUN=true
TARGET_ARTICLE_COUNT=0
DOMESTIC_RATIO=0.0
RECENT_PUBLISHED_DAYS=14
MIN_TIER_A_RATIO=0.0
QUALITY_THRESHOLD=80
REQUIRE_LLM_FOR_PUBLISH=true
ALLOW_GOOGLE_REDIRECT_CITATION=false
STRICT_WEB_PUBLISHED_AT=true
MAX_ENTRIES_PER_SOURCE=0
MIN_RANK_SCORE_FOR_COMPOSE=80
SOURCE_HEALTH_GATE_ENABLED=true
MIN_PRIMARY_INDUSTRY_SOURCES_OK=2
MIN_PRIMARY_INDUSTRY_ITEMS=3
MAX_ARTICLE_AGE_HOURS=48
MAX_TIER_A_ARTICLE_AGE_HOURS=48
MIN_PUBLISH_COUNT=1

# LLM (optional; failover: primary -> fallback DeepSeek -> backup gpt-5.3-codex -> secondary Grok)
LLM_API_KEY=
LLM_BASE_URL=http://186.244.244.142:8080/v1
LLM_MODEL=gpt-5.4
LLM_MAX_TOKENS=6000
LLM_TEMPERATURE=0.1
LLM_BACKUP_API_KEY=
LLM_BACKUP_BASE_URL=https://a-ocnfniawgw.cn-shanghai.fcapp.run/v1
LLM_BACKUP_MODEL=gpt-5.3-codex
LLM_SECONDARY_BACKUP_API_KEY=
LLM_SECONDARY_BACKUP_BASE_URL=https://grok.223344567.xyz
LLM_SECONDARY_BACKUP_MODEL=grok-4.20-fast
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=https://api.deepseek.com/anthropic
LLM_FALLBACK_MODEL=deepseek-v4-flash

# WeChat Official Account
WECHAT_ENABLE_PUBLISH=false
WECHAT_AUTO_PUBLISH=false
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_USE_STABLE_TOKEN=true
WECHAT_AUTHOR=Global Aviation Digest
WECHAT_THUMB_MEDIA_ID=
WECHAT_PROXY=
WEB_DIGEST_BASE_URL=https://podcast-files.hudawang.cn/digest
COPYRIGHT_NOTICE_URL=

# Alerts
ALERT_WEBHOOK_URL=

# Podcast TTS
DASHSCOPE_API_KEY=
# Primary: HK local Qwen3-TTS-0.6B (slow on CPU; stable, no remote demo queue)
QWEN_TTS_PRIMARY_URL=https://tts.hudawang.cn
# Fallback: US qwen-tts2api (remote demo proxy, faster when not congested)
QWEN_TTS_FALLBACK_URL=http://186.244.244.142:8825
# Legacy alias for fallback only
# QWEN_TTS_URL=http://186.244.244.142:8825
QWEN_TTS_API_KEY=
# true = try QWEN_TTS_FALLBACK_URL (cherry/ethan) before PRIMARY (serena/aiden on 0.6B)
# HK 0.6B cannot use cherry/ethan until the server model/voice set is upgraded
QWEN_TTS_PREFER_CLOUD_VOICES=false
# Per-backend voice IDs (千羽=女, 虎机长=男). HK list: curl https://tts.hudawang.cn/v1/voices
# TTS_QWEN_LOCAL_VOICE_FEMALE=vivian
# TTS_QWEN_LOCAL_VOICE_MALE=uncle_fu
# TTS_QWEN_CLOUD_VOICE_FEMALE=cherry
# TTS_QWEN_CLOUD_VOICE_MALE=ethan
# TTS_VOICE_FEMALE=Cherry
# TTS_VOICE_MALE=Ethan
# Force one backend for A/B: qwen_local | qwen_cloud | edge | dashscope
# TTS_FORCE_BACKEND=qwen_local

# PDF Extraction & Narration
MINERU=

# Self-hosted static site
STATIC_ROOT=/www/wwwroot/podcast-files.hudawang.cn
STATIC_PUBLIC_BASE_URL=https://podcast-files.hudawang.cn

# Image Generation
# primary: gpt-5.3-codex via OpenAI Responses API (image_generation tool)
# backup: Grok imagine (faster fallback, lower quality)
PUBLIC_IMAGE_SEARCH_TIMEOUT_SECONDS=5
WEB_IMAGE_SEARCH_BUDGET_SECONDS=20
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=https://a-ocnfniawgw.cn-shanghai.fcapp.run
IMAGE_GEN_MODEL=gpt-5.3-codex
IMAGE_GEN_BACKUP_API_KEY=
IMAGE_GEN_BACKUP_BASE_URL=https://grok.223344567.xyz
IMAGE_GEN_BACKUP_MODEL=grok-imagine-image-lite
